using Gtk 4.0;

template $SwaySettingsPagesPulseDeviceComboRowItem: Gtk.Box {
  orientation: horizontal;

  Image {
    icon-name: bind template.icon;
    use-fallback: true;
    margin-start: 6;
    margin-end: 6;
  }

  Label {
    label: bind template.display_name;
    ellipsize: end;
  }

  Image {
    visible: bind template.selected;
    icon-name: "checkmark-symbolic";
  }
}
